# ============================================================
# Backend Environment Variables (Production)
# Copy this file to .env on your hosting server
# ============================================================

# Allianz API Credentials
ALLIANZ_CONSUMER_KEY=your_consumer_key_here
ALLIANZ_CONSUMER_SECRET=your_consumer_secret_here

# Allianz API Base URL
# UAT: https://asia-uat-malaysia.apis.allianz.com
# Production: https://asia-malaysia.apis.allianz.com
ALLIANZ_BASE_URL=https://asia-uat-malaysia.apis.allianz.com

# Partner ID assigned by Allianz
ALLIANZ_PARTNER_ID=DCAUTO

# SenangPay Payment Gateway
SENANGPAY_SECRET_KEY=your_senangpay_secret_key
SENANGPAY_MERCHANT_ID=your_senangpay_merchant_id

# Allianz Callback Verification
CALLBACK_HMAC_SECRET=generate-a-strong-random-string-here

# Server config
PORT=3001

# CORS - your frontend URL (the domain where your site is hosted)
FRONTEND_URL=http://gentle-emerald-armadillo.103-10-78-80.cpanel.site
